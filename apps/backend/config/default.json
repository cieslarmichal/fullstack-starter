{
  "database": {
    "ssl": false,
    "pool": {
      "min": 2,
      "max": 20,
      "idleTimeoutMillis": 30000,
      "connectionTimeoutMillis": 10000,
      "maxLifetimeSeconds": 600,
      "keepAlive": true,
      "keepAliveInitialDelayMillis": 5000
    }
  },
  "aws": {
    "region": "eu-central-1",
    "bucketName": "fullstack-starter-bucket"
  },
  "frontendUrl": "http://localhost:5173",
  "hashSaltRounds": 12,
  "logLevel": "debug",
  "resend": {
    "fromEmail": "Fullstack Starter <noreply@example.com>",
    "emails": {
      "verifyAccount": {
        "templateFile": "verifyAccount.html",
        "subject": "Confirm your email address"
      },
      "resetPassword": {
        "templateFile": "resetPassword.html",
        "subject": "Reset your password"
      }
    }
  },
  "server": {
    "host": "0.0.0.0",
    "port": 5000
  },
  "rateLimit": {
    "global": {
      "max": 100,
      "timeWindow": 60000
    },
    "register": {
      "max": 5,
      "timeWindow": 600000
    },
    "login": {
      "max": 10,
      "timeWindow": 600000
    },
    "logout": {
      "max": 20,
      "timeWindow": 60000
    },
    "refreshToken": {
      "max": 30,
      "timeWindow": 60000
    },
    "profile": {
      "max": 50,
      "timeWindow": 60000
    },
    "accountDeletion": {
      "max": 3,
      "timeWindow": 3600000
    },
    "passwordReset": {
      "max": 5,
      "timeWindow": 600000
    },
    "uploadImage": {
      "max": 20,
      "timeWindow": 60000
    }
  },
  "token": {
    "access": {
      "expiresIn": 600
    },
    "refresh": {
      "expiresIn": 604800,
      "graceMs": 10000,
      "idempotencyMs": 3000
    },
    "accountVerification": {
      "expiresIn": 86400
    },
    "resetPassword": {
      "expiresIn": 3600
    }
  },
  "image": {
    "maxFileSizeBytes": 3145728,
    "allowedContentTypes": ["image/jpeg", "image/jpg", "image/png", "image/webp"]
  },
  "jobs": {
    "enabled": true,
    "emailQueueName": "send-email"
  }
}
