{
  "name": "@apps/backend",
  "type": "module",
  "scripts": {
    "dev": "node --watch-path=./src --watch-path=./config src/index.ts",
    "build": "tsc --build tsconfig.prod.json",
    "build:dev": "tsc --build tsconfig.json",
    "test": "NODE_ENV=test vitest --config vitest.config.js",
    "test:ci": "npm run test -- --run",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1044.0",
    "@aws-sdk/lib-storage": "3.1044.0",
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "11.2.0",
    "@fastify/multipart": "10.0.0",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/type-provider-typebox": "6.1.0",
    "bcrypt": "6.0.0",
    "config": "4.4.1",
    "fastify": "5.8.5",
    "jsonwebtoken": "9.0.3",
    "nanoid": "5.1.11",
    "pg": "8.20.0",
    "pg-boss": "12.18.2",
    "pino": "10.3.1",
    "resend": "6.12.3",
    "sharp": "0.34.5",
    "typebox": "1.1.38",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "10.4.0",
    "@types/bcrypt": "6.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/pg": "8.20.0"
  }
}
